{
  "title": "Tender Monitor",
  "uid": "tender-monitor-007",
  "schemaVersion": 38,
  "version": 1,
  "tags": ["monitor", "tender", "business"],
  "timezone": "browser",
  "time": { "from": "now-24h", "to": "now" },
  "refresh": "1m",
  "graphTooltip": 1,
  "panels": [
    {
      "type": "stat",
      "title": "Тендеров найдено (24ч)",
      "id": 1,
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(monitor_tenders_found_total[24h]))",
          "legendFormat": "Тендеры",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Циклов выполнено (24ч)",
      "id": 2,
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(monitor_cycles_total[24h]))",
          "legendFormat": "Циклы",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Писем отправлено (24ч)",
      "id": 3,
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(monitor_emails_sent_total[24h]))",
          "legendFormat": "Письма",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Ошибок API (24ч)",
      "id": 4,
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["sum"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(monitor_api_errors_total[24h]))",
          "legendFormat": "Ошибки",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Новые тендеры по времени",
      "id": 5,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by(subscription_id, source) (increase(monitor_tenders_found_total[$__rate_interval]))",
          "legendFormat": "sub={{subscription_id}} src={{source}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Результаты циклов (found / empty / error)",
      "id": 6,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          {
            "matcher": { "id": "byFrameRefID", "options": "error" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byFrameRefID", "options": "found" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(monitor_cycles_total{result=\"found\"}[$__rate_interval]))",
          "legendFormat": "found",
          "refId": "found"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(monitor_cycles_total{result=\"empty\"}[$__rate_interval]))",
          "legendFormat": "empty",
          "refId": "empty"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(monitor_cycles_total{result=\"error\"}[$__rate_interval]))",
          "legendFormat": "error",
          "refId": "error"
        }
      ]
    },
    {
      "type": "bargauge",
      "title": "Топ подписок по найденным тендерам (24ч)",
      "id": 7,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["sum"] },
        "displayMode": "gradient",
        "valueMode": "color",
        "showUnfilled": true,
        "minVizWidth": 0,
        "minVizHeight": 10
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sort_desc(sum by(subscription_id) (increase(monitor_tenders_found_total[24h])))",
          "legendFormat": "sub={{subscription_id}}",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Длительность цикла (p95, медиана)",
      "id": 8,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1, "fillOpacity": 5 }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by(le) (rate(monitor_cycle_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p95",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum by(le) (rate(monitor_cycle_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p50",
          "refId": "B"
        }
      ]
    },
    {
      "type": "logs",
      "title": "Логи монитора (новые тендеры)",
      "id": 9,
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{container=\"app\"} | json | message =~ \"new=\\\\d+\"",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    }
  ]
}
