# Domain (for Caddy SSL)
APP_DOMAIN=tender.yourdomain.com

# Database
DB_NAME=appdb
DB_USER=appuser
DB_PASSWORD=CHANGE_ME_strong_db_password

# Redis
REDIS_PASSWORD=CHANGE_ME_redis_password

# Admin panel credentials (Basic Auth)
ADMIN_USER=admin
ADMIN_PASSWORD=CHANGE_ME_admin_password

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=noreply@yourdomain.com

# Gosplan API
GOSPLAN_BASE_URL=https://v2.gosplan.info
GOSPLAN_API_KEY=
