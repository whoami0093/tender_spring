# Base URL (используется Grafana для ссылок в алертах)
# Без домена: http://VPS_IP  |  С доменом: https://yourdomain.com
APP_BASE_URL=http://localhost

# Domain (для Caddy SSL — раскомментировать когда будет домен)
# APP_DOMAIN=tender.yourdomain.com

# Database
DB_NAME=appdb
DB_USER=appuser
DB_PASSWORD=CHANGE_ME_strong_db_password

# Redis
REDIS_PASSWORD=CHANGE_ME_redis_password

# Admin panel credentials (Basic Auth)
ADMIN_USER=admin
ADMIN_PASSWORD=CHANGE_ME_admin_password

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=noreply@yourdomain.com

# Gosplan API
GOSPLAN_BASE_URL=https://v2.gosplan.info
GOSPLAN_API_KEY=

# Monitoring (Grafana + Telegram alerts)
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana_password
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
